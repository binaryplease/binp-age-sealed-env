# server.env.example — template for the SHARED vault.
#
# Copy this to `secrets/server.env`, fill in real values, then seal it:
#   cp secrets/server.env.example secrets/server.env
#   $EDITOR secrets/server.env
#   bun run scripts/secrets-seal.ts        # -> server.env.age, deletes the plaintext
#
# Plain dotenv: KEY=value, one per line. Blank lines and #-comments are ignored,
# and empty values are intentionally NOT exported. A leading `export ` and one
# layer of surrounding quotes are stripped.

EXAMPLE_API_KEY=replace-with-a-real-key
DATABASE_URL=postgres://user:password@localhost:5432/app
