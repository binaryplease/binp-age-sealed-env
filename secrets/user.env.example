# user.env.example — template for a PERSONAL override.
#
# On top of the shared server.env.age, each person can keep an override that only
# loads on their own machine — handy for pointing at your own credentials without
# touching the shared vault. Put ONLY the vars you override here; everything else
# keeps coming from the shared vault.
#
# Copy this to `secrets/user.<you>.env` (<you> = your OS login, or $VAULT_USER),
# then seal it to yourself alone:
#   cp secrets/user.env.example secrets/user.$USER.env
#   $EDITOR secrets/user.$USER.env
#   # optional: secrets/user.$USER.recipients.txt with just your key
#   bun run scripts/secrets-seal.ts --user     # -> user.$USER.env.age
#
# Precedence, highest first: shell env > personal override > shared vault.

EXAMPLE_API_KEY=my-personal-key
